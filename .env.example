# Copy to .env and edit for your deployment.
# This file is the source of truth for env-driven config consumed by
# docker-compose.yml. The defaults below match a CPU-only R530-style
# deployment (visual indexing enabled with ColSmolVLM, aggressive async queue).

# -----------------------------------------------------------------------------
# Backend selection
# -----------------------------------------------------------------------------
# Which backend handles ingest/search by default. The agent can override
# per-call with the `backend` arg on each tool.
INGEST_BACKEND=qdrant

# Default mode for search_documents when retrieval_mode isn't passed per-call.
# auto: fusion if KB has visual index, else text_only
RETRIEVAL_MODE=auto

# Default for ingest_document's enable_visual_index arg. true = ColPali side
# runs on every ingest unless the call explicitly opts out.
INGEST_DEFAULT_VISUAL_INDEX=true

# -----------------------------------------------------------------------------
# Text embeddings (llama-server)
# -----------------------------------------------------------------------------
# The model file in ./models that llama-server loads. Get with e.g.:
#   huggingface-cli download CompendiumLabs/bge-small-en-v1.5-gguf \
#     bge-small-en-v1.5-f16.gguf --local-dir ./models
LLAMA_MODEL_FILE=bge-small-en-v1.5-f16.gguf
LLAMA_CTX_SIZE=8192
LLAMA_PORT=8081

# Model name the Quarkus side reports in payload + cosmetically passes to
# llama-server (the value is just a label; llama-server ignores it).
EMBED_MODEL=bge-small-en-v1.5
EMBED_BATCH_SIZE=64

# -----------------------------------------------------------------------------
# ColPali sidecar
# -----------------------------------------------------------------------------
COLPALI_DOCKERFILE=Dockerfile.cpu        # or Dockerfile.cuda on a GPU host
COLPALI_MODEL=vidore/colsmolvlm-v0.1     # smaller; CPU-feasible
COLPALI_DEVICE=cpu                        # cpu / cuda / mps / auto
COLPALI_DTYPE=float32                     # CPU prefers float32; GPU uses bfloat16
COLPALI_MAX_BATCH_SIZE=4                  # smaller batches on CPU
COLPALI_BATCH_SIZE=4                      # Java-side batch (mirrors the above)
COLPALI_PORT=8090

# -----------------------------------------------------------------------------
# Async ingest queue
# -----------------------------------------------------------------------------
# PDFs with >= this many pages get queued instead of running synchronously.
# Lower this on CPU sidecars; raise it on GPU. 5 is a sensible R530 default.
INGEST_ASYNC_THRESHOLD_PAGES=5
INGEST_QUEUE_WORKERS=1                    # don't oversubscribe CPU

# -----------------------------------------------------------------------------
# Fusion / retrieval
# -----------------------------------------------------------------------------
FUSION_STRATEGY=rrf                       # or 'weighted'

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# -----------------------------------------------------------------------------
# MCP HTTP transport
# -----------------------------------------------------------------------------
PDF_RAG_PORT=8080
# Restrict CORS for production. * is OK for an internal-only deployment.
MCP_CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Open WebUI backend (OPTIONAL — leave unset to keep Qdrant-only)
# -----------------------------------------------------------------------------
# Uncomment and set if you want to wire OpenWebUiBackend as a parallel target.
# OPEN_WEBUI_BASE_URL=http://your-cluster-host:3000
# OPEN_WEBUI_API_KEY=
